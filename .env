# RivicQ Environment Configuration
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000
NODE_ENV=development

# Gemini AI API Key (required for AI-powered security scanning)
API_KEY=your_gemini_api_key_here

# CORS Configuration (comma-separated origins for production)
# Example: https://rivicq.de,https://www.rivicq.de
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Production URLs (update when deploying)
PRODUCTION_URL=https://rivicq.de
API_BASE_URL=https://api.rivicq.de

# SMTP Configuration (for email sending)
# Brevo SMTP (formerly Sendinblue) - recommended for production
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM=noreply@rivicq.de
