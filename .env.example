# RivicQ Website Environment Variables
# Copy to .env and fill values

# Required for /api/scan-security
API_KEY=your_gemini_api_key

# Server
PORT=3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: tighten CORS in production (comma-separated origins)
# Example: https://rivicq.com,https://www.rivicq.com
CORS_ORIGIN=http://localhost:5173

# SMTP Configuration (for email sending to hello@rivicq.de)
# Brevo SMTP (formerly Sendinblue) - recommended free option
# Get credentials at: https://app.brevo.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@rivicq.de

# Database (Prisma)
# Use SQLite for local dev: DATABASE_URL=file:./dev.db
DATABASE_URL=file:./dev.db
PRISMA_PROVIDER=sqlite

# Optional notification email
NOTIFY_EMAIL=hello@rivicq.de
