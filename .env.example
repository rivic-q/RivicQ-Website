# RivicQ Website Environment Variables
# Copy to .env and fill values

# Form endpoint — set to a third-party form service for GitHub Pages
# Web3Forms (free): https://api.web3forms.com/submit
# Formspree (free):  https://formspree.io/f/your_form_id
# Leave empty to use local /api/contact (requires running server.js)
VITE_FORM_ENDPOINT=
