# RivicQ Website Environment Variables
# Copy to .env and fill values (optional — site works without .env)

# Form endpoint — set to a third-party form service for production
# Web3Forms (free, 250/mo):  https://api.web3forms.com/submit
# Formspree (free, 50/mo):    https://formspree.io/f/your_form_id
# Leave empty to use /api/contact (local dev with server.js)
VITE_FORM_ENDPOINT=
