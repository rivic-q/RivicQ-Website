# RivicQ Website Environment Variables
# Copy to .env and fill values

# Server
NODE_ENV=development
PORT=3000

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://rivicq.de,https://www.rivicq.de

# SMTP (Brevo / Sendinblue)
# Leave empty to log inquiries only (no email delivery)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rivicq.de

# Form Endpoint
# Leave empty to use local /api/contact (requires server.js running)
# For production, point to a third-party form service or keep /api/contact
VITE_FORM_ENDPOINT=/api/contact

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
