{
  "name": "rivicq",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "server": "node server.js",
    "start": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:build && npm run test:runtime",
    "test:build": "vite build",
    "test:runtime": "node --check server.js",
    "prod:check": "npm run test",
    "lint": "tsc --noEmit && echo 'TypeScript check passed'",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,html}\""
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "lucide-react": "^0.563.0",
    "nodemailer": "^8.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "avoid"
  }
}
