{
  "name": "rivicq",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "node server.js",
    "start": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit && echo 'TypeScript check passed'",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests configured yet. See: PRODUCTION_TEST_CHECKLIST.md' && exit 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,html}\"",
    "prod:check": "bash scripts/prod-check.sh",
    "server:start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "lucide-react": "^0.563.0",
    "nodemailer": "^6.9.16",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "prettier": "^3.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "avoid"
  }
